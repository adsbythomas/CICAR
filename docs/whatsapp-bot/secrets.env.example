# =============================================================================
# Bot WhatsApp CICAR · Variables de entorno (TEMPLATE)
# =============================================================================
# COPIAR este archivo a secrets.env y rellenar con los valores reales.
# NUNCA commitear secrets.env al repo (ya está en .gitignore).
# Estas credenciales se cargan en n8n Cloud → Credentials. Este archivo
# es sólo el registro maestro local para mantener todo en un solo lugar.
# =============================================================================

# -----------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# -----------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_BUSINESS_ACCOUNT_ID=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN_PERMANENTE=
META_VERIFY_TOKEN=                # Inventar string random largo (32+ chars)
META_API_VERSION=v21.0

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_STORAGE_BUCKET=resultados-medicos

# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
N8N_BASE_URL=https://cicar.app.n8n.cloud
N8N_WEBHOOK_META=https://cicar.app.n8n.cloud/webhook/meta-incoming
N8N_WEBHOOK_OMNIA=https://cicar.app.n8n.cloud/webhook/omnia-result-ready

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Omnia Salud (pendiente · completar cuando llegue la doc)
# -----------------------------------------------------------------------------
OMNIA_API_BASE_URL=
OMNIA_API_KEY=
OMNIA_WEBHOOK_SECRET=             # Para validar firma HMAC de webhooks entrantes
OMNIA_SANDBOX=true                # Cambiar a false en producción

# -----------------------------------------------------------------------------
# Chatwoot
# -----------------------------------------------------------------------------
CHATWOOT_URL=https://app.chatwoot.com
CHATWOOT_API_KEY=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=

# -----------------------------------------------------------------------------
# Observabilidad
# -----------------------------------------------------------------------------
SENTRY_DSN=
BETTERSTACK_HEARTBEAT_CRON_24H=
BETTERSTACK_HEARTBEAT_CRON_2H=
BETTERSTACK_HEARTBEAT_HEALTH=
BETTERSTACK_LOGS_TOKEN=

# -----------------------------------------------------------------------------
# Legal / regulatorio
# -----------------------------------------------------------------------------
AAIP_REGISTRO_NRO=
CICAR_RAZON_SOCIAL=
CICAR_CUIT=
CICAR_DIRECCION_LEGAL=
CICAR_RESPONSABLE_DATOS_EMAIL=

# -----------------------------------------------------------------------------
# Configuración del bot
# -----------------------------------------------------------------------------
BOT_TIMEZONE=America/Argentina/Buenos_Aires
BOT_HORARIO_RECORDATORIOS_DESDE=09:00
BOT_HORARIO_RECORDATORIOS_HASTA=21:00
BOT_HANDOFF_PAUSA_HORAS=4
BOT_MAX_INTENTOS_FALLIDOS=3
